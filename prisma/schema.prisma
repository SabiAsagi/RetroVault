generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                 String            @id @default(uuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  password           String?
  image              String?
  nickname           String?           @unique
  bio                String?
  role               String            @default("USER")
  visibility         String            @default("PUBLIC")
  theme              String            @default("dark")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isBanned           Boolean           @default(false)
  profileLikes       Int               @default(0)
  profileViews       Int               @default(0)
  accounts           Account[]
  adminLogs          AdminLog[]        @relation("AdminActionLogs")
  collectionGroups   CollectionGroup[]
  collections        CollectionItem[]
  requestedCompanies Company[]         @relation("RequestedCompanies")
  receivedMessages   DirectMessage[]   @relation("ReceivedMessages")
  sentMessages       DirectMessage[]   @relation("SentMessages")
  editRequests       EditRequest[]     @relation("UserEditRequests")
  friendOf           Friendship[]      @relation("FriendFriendships")
  friendships        Friendship[]      @relation("UserFriendships")
  requestedGames     Game[]            @relation("RequestedGames")
  notifications      Notification[]    @relation("UserNotifications")
  requestedPlatforms Platform[]        @relation("RequestedPlatforms")
  reports            Report[]          @relation("UserReports")
  reviews            Review[]          @relation("UserReviews")
  sessions           Session[]
  achievements       UserAchievement[]

  @@index([name])
  @@index([isBanned])
  @@index([role])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id                String           @id @default(uuid())
  title             String
  releaseDate       String?
  releaseYear       Int
  genre             String
  genre_ko          String?
  country           String?
  coverImageUrl     String?
  description       String?
  historicalContext String?
  popularity        Int              @default(0)
  rating            Float?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  platformId        String
  developerId       String?
  publisherId       String?
  referenceUrl      String?
  rejectReason      String?
  requestedById     String?
  status            String           @default("PENDING")
  installSize       String?
  originalTitle     String?
  pcSpecsMin        String?
  pcSpecsRec        String?
  releaseStatus     String           @default("RELEASED")
  shortDescription  String?
  trailerUrl        String?
  views             Int              @default(0)
  isAdult           Boolean          @default(false)
  ageRating         String?          @default("ALL")
  collectedBy       CollectionItem[]
  developer         Company?         @relation("DevelopedGames", fields: [developerId], references: [id])
  platform          Platform         @relation(fields: [platformId], references: [id])
  publisher         Company?         @relation("PublishedGames", fields: [publisherId], references: [id])
  requestedBy       User?            @relation("RequestedGames", fields: [requestedById], references: [id])
  reviews           Review[]         @relation("GameReviews")
  screenshots       Screenshot[]
  timelineEvents    TimelineEvent[]

  @@unique([title, platformId, releaseYear])
  @@index([releaseYear])
  @@index([genre])
  @@index([country])
  @@index([platformId])
  @@index([developerId])
  @@index([publisherId])
  @@index([status])
  @@index([releaseStatus])
  @@index([views, popularity])
  @@index([createdAt])
}

model Platform {
  id              String          @id @default(uuid())
  name            String          @unique
  name_ko         String?
  manufacturer    String
  manufacturer_ko String?
  generation      Int?
  releaseYear     Int
  imageUrl        String?
  logoUrl         String?
  description     String?
  description_ko  String?
  innovationPoint String?
  type            String          @default("HOME")
  variants        String?
  createdAt       DateTime        @default(now())
  rejectReason    String?
  requestedById   String?
  status          String          @default("APPROVED")
  updatedAt       DateTime        @default(now()) @updatedAt
  discontinued    Boolean?
  launchPrice     String?
  totalSales      String?
  additionalInput String?
  country         String?
  specs           String?
  specs_ko        String?
  specs_cpu       String?
  specs_cpu_ko    String?
  specs_gpu       String?
  specs_gpu_ko    String?
  specs_memory    String?
  specs_memory_ko String?
  peripherals     String?
  peripherals_ko  String?
  releaseStatus   String?         @default("RELEASED")
  views           Int             @default(0)
  gamesCount      Int             @default(0)
  mediaFormat     String?
  mediaFormat_ko  String?
  releaseDate     String?
  games           Game[]
  requestedBy     User?           @relation("RequestedPlatforms", fields: [requestedById], references: [id])
  timelineEvents  TimelineEvent[]

  @@index([manufacturer])
  @@index([generation])
  @@index([releaseYear])
  @@index([type])
  @@index([status])
  @@index([views])
}

model Company {
  id                 String   @id @default(uuid())
  name               String   @unique
  name_ko            String?
  type               String
  country            String?
  country_ko         String?
  logoUrl            String?
  description        String?
  description_ko     String?
  foundedAt          String?
  websiteUrl         String?
  createdAt          DateTime @default(now())
  rejectReason       String?
  requestedById      String?
  status             String   @default("APPROVED")
  updatedAt          DateTime @default(now()) @updatedAt
  companyStatus         String?
  companyStatus_ko      String?
  flagshipFranchises    String?
  flagshipFranchises_ko String?
  keyFigures            String?
  keyFigures_ko         String?
  views                 Int      @default(0)
  subsidiaries          String?
  subsidiaries_ko       String?
  requestedBy           User?    @relation("RequestedCompanies", fields: [requestedById], references: [id])
  developedGames     Game[]   @relation("DevelopedGames")
  publishedGames     Game[]   @relation("PublishedGames")

  @@index([type])
  @@index([country])
  @@index([status])
  @@index([companyStatus])
  @@index([views])
}

model Screenshot {
  id       String  @id @default(uuid())
  gameId   String
  imageUrl String
  caption  String?
  game     Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

model CollectionItem {
  id              String                @id @default(uuid())
  userId          String
  gameId          String
  ownershipStatus String
  purchaseType    String?
  condition       String?
  region          String?
  purchaseDate    String?
  purchasePrice   Int?
  memo            String?
  playStartDate   String?
  clearDate       String?
  playTime        Int?
  rating          Int?                  @default(0)
  visibility      String?               @default("public")
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  playStatus      String?               @default("UNPLAYED")
  groups          CollectionGroupItem[]
  game            Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId, sortOrder])
  @@index([gameId])
  @@index([visibility])
  @@index([ownershipStatus])
  @@index([playStatus])
  @@index([rating])
  @@index([createdAt])
}

model Achievement {
  id             String            @id @default(uuid())
  name           String            @unique
  description    String
  badgeImageUrl  String
  conditionType  String
  conditionValue Int
  users          UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime?
  progress      Int         @default(0)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
}

model Report {
  id         String    @id @default(uuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String    @default("PENDING")
  adminMemo  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  reporter   User      @relation("UserReports", fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
}

model EditRequest {
  id            String   @id @default(uuid())
  targetType    String
  targetId      String
  requestedById String?
  proposedData  String
  reason        String?
  status        String   @default("PENDING")
  adminMemo     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requestedBy   User?    @relation("UserEditRequests", fields: [requestedById], references: [id])

  @@index([targetType, targetId])
  @@index([requestedById])
  @@index([status])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  beforeJson String?
  afterJson  String?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActionLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model TimelineEvent {
  id                String    @id @default(uuid())
  year              Int
  title             String
  type              String
  description       String
  imageUrl          String?
  innovation        String?
  era               String
  country           String?
  isVisible         Boolean   @default(true)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  relatedGameId     String?
  relatedPlatformId String?
  game              Game?     @relation(fields: [relatedGameId], references: [id])
  platform          Platform? @relation(fields: [relatedPlatformId], references: [id])

  @@index([year])
  @@index([type])
  @@index([isVisible, sortOrder])
  @@index([relatedGameId])
  @@index([relatedPlatformId])
}

model CollectionGroup {
  id          String                @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  likes       Int                   @default(0)
  views       Int                   @default(0)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionGroupItem[]

  @@index([userId])
  @@index([isPublic, likes, views])
  @@index([createdAt])
}

model CollectionGroupItem {
  id      String          @id @default(uuid())
  groupId String
  itemId  String
  group   CollectionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  item    CollectionItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([groupId, itemId])
  @@index([itemId])
}

model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, isRead, createdAt])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId, status])
  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([type])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation("GameReviews", fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([rating])
  @@index([createdAt])
}
