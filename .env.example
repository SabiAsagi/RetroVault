# Database (Vercel Postgres / Neon)
# Prisma uses the pooled URL for app traffic and the non-pooling URL for schema changes.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# OAuth providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# IGDB / Twitch application
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# IGDB sync options
# 0 means no maximum. Set a smaller number while testing.
IGDB_SYNC_MAX_PLATFORMS="0"
IGDB_SYNC_MAX_COMPANIES="0"
IGDB_SYNC_MAX_GAMES="0"
# Games released before this year are excluded.
IGDB_SYNC_MIN_YEAR="1950"
# Adult-themed games are excluded unless explicitly enabled.
IGDB_SYNC_INCLUDE_ADULT="false"

# Seed options
ADMIN_INITIAL_EMAIL="admin@retrovault.kr"
ADMIN_INITIAL_PASSWORD="change-this-password"
SEED_DEMO_USERS="false"
