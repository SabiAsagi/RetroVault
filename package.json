{
  "name": "retrovault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma db push && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:consoles": "tsx prisma/seed_wiki_consoles.ts",
    "sync:games": "tsx scripts/sync-games.ts",
    "sync:platforms": "tsx scripts/sync-platforms.ts",
    "sync:companies": "tsx scripts/sync-companies.ts",
    "sync:all": "npm run sync:platforms && npm run sync:companies && npm run sync:games",
    "translate:platforms": "tsx scripts/translate-platforms.ts",
    "translate:companies": "tsx scripts/translate-companies.ts",
    "translate:genres": "tsx scripts/translate-genres.ts",
    "translate:ai": "tsx scripts/translate-ai.ts",
    "translate:all": "npm run translate:platforms && npm run translate:companies && npm run translate:genres",
    "translate:sql": "node scripts/retrovault-translate.mjs",
    "translate:apply": "node scripts/retrovault-translate.mjs --apply"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.8.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.4.1",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.5",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.6.0",
    "translate": "^3.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.15",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
